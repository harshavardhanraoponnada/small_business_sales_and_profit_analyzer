# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/infosys_app?schema=public

# Redis Cache & Rate Limiting
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=replace_with_strong_random_secret
JWT_EXPIRY=8h

# CORS
CORS_ORIGINS=http://localhost:5174

# Server Configuration
NODE_ENV=development
PORT=5000
JSON_BODY_LIMIT=1mb
TRUST_PROXY=0
MAX_UPLOAD_SIZE_BYTES=10485760

# External Services
ML_SERVICE_URL=http://localhost:5001

# Email Configuration
MAIL_USER=your_email@example.com
MAIL_PASS=your_email_app_password

# Rate Limiting
LOGIN_RATE_LIMIT_WINDOW_MS=600000
LOGIN_RATE_LIMIT_MAX=10
FORGOT_PASSWORD_RATE_LIMIT_WINDOW_MS=600000
FORGOT_PASSWORD_RATE_LIMIT_MAX=5
RESET_PASSWORD_RATE_LIMIT_WINDOW_MS=600000
RESET_PASSWORD_RATE_LIMIT_MAX=10

# Logging
LOG_LEVEL=info