// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// User model - represents system users with roles
model User {
  id                      String      @id @default(cuid())
  username                String      @unique
  email                   String      @unique
  password_hash           String
  role                    String      // OWNER, ACCOUNTANT, STAFF
  reportFrequency         String?     // DAILY, WEEKLY, MONTHLY
  reportFormat            String?     // PDF, EMAIL, EXCEL
  receiveScheduledReports Boolean     @default(false)
  created_at              DateTime    @default(now())
  updated_at              DateTime    @updatedAt

  // Relations
  sales                   Sale[]
  expenses                Expense[]
  auditLogs              AuditLog[]

  @@index([role])
  @@index([created_at])
}

// Category model
model Category {
  id                String      @id @default(cuid())
  name              String      @unique
  is_deleted        Boolean     @default(false)
  created_at        DateTime    @default(now())
  updated_at        DateTime    @updatedAt

  // Relations
  brands            Brand[]
  products          Product[]

  @@index([is_deleted])
  @@index([created_at])
}

// Brand model
model Brand {
  id                String      @id @default(cuid())
  name              String
  category_id       String
  is_deleted        Boolean     @default(false)
  created_at        DateTime    @default(now())
  updated_at        DateTime    @updatedAt

  // Relations
  category          Category    @relation(fields: [category_id], references: [id])
  models            Model[]

  @@unique([name, category_id])
  @@index([category_id])
  @@index([is_deleted])
  @@index([created_at])
}

// Model (product model variant)
model Model {
  id                String      @id @default(cuid())
  name              String
  brand_id          String
  is_deleted        Boolean     @default(false)
  created_at        DateTime    @default(now())
  updated_at        DateTime    @updatedAt

  // Relations
  brand             Brand       @relation(fields: [brand_id], references: [id])
  variants          Variant[]

  @@unique([name, brand_id])
  @@index([brand_id])
  @@index([is_deleted])
  @@index([created_at])
}

// Variant model - storage/color variants of products
model Variant {
  id                String      @id @default(cuid())
  model_id          String
  variant_name      String      // e.g., "128GB Black", "256GB Gold"
  stock             Int         @default(0)
  prices            String      // JSON string storing price variants
  is_deleted        Boolean     @default(false)
  created_at        DateTime    @default(now())
  updated_at        DateTime    @updatedAt

  // Relations
  model             Model       @relation(fields: [model_id], references: [id])
  sales             Sale[]

  @@unique([model_id, variant_name])
  @@index([model_id])
  @@index([is_deleted])
  @@index([created_at])
}

// Product model
model Product {
  id                String      @id @default(cuid())
  name              String      @unique
  brand            String
  category_id       String
  stock             Int         @default(0)
  prices            String      // JSON string with price variants
  is_deleted        Boolean     @default(false)
  created_at        DateTime    @default(now())
  updated_at        DateTime    @updatedAt

  // Relations
  category          Category    @relation(fields: [category_id], references: [id])
  sales             Sale[]

  @@index([category_id])
  @@index([name])
  @@index([is_deleted])
  @@index([created_at])
}

// Sale model
model Sale {
  id                String      @id @default(cuid())
  date              DateTime    @default(now())
  variant_id        String?
  product_id        String?
  quantity          Int
  unit_price        Decimal     @db.Decimal(10, 2)
  total             Decimal     @db.Decimal(12, 2)
  created_by        String
  is_deleted        Boolean     @default(false)
  created_at        DateTime    @default(now())
  updated_at        DateTime    @updatedAt

  // Relations
  variant           Variant?    @relation(fields: [variant_id], references: [id])
  product           Product?    @relation(fields: [product_id], references: [id])
  user              User        @relation(fields: [created_by], references: [id])

  @@index([variant_id])
  @@index([product_id])
  @@index([created_by])
  @@index([date])
  @@index([is_deleted])
  @@index([created_at])
}

// Expense model
model Expense {
  id                String      @id @default(cuid())
  date              DateTime    @default(now())
  category          String      // RENT, UTILITIES, SUPPLIES, etc.
  amount            Decimal     @db.Decimal(10, 2)
  description       String
  created_by        String
  is_deleted        Boolean     @default(false)
  created_at        DateTime    @default(now())
  updated_at        DateTime    @updatedAt

  // Relations
  user              User        @relation(fields: [created_by], references: [id])

  @@index([category])
  @@index([created_by])
  @@index([date])
  @@index([is_deleted])
  @@index([created_at])
}

// AuditLog model - track all changes for compliance
model AuditLog {
  id                String      @id @default(cuid())
  action            String      // SALE_ADD, EXPENSE_UPDATE, etc.
  username          String
  user_role         String
  details           String      // JSON details of change
  created_by        String
  created_at        DateTime    @default(now())

  // Relations
  user              User        @relation(fields: [created_by], references: [id])

  @@index([action])
  @@index([created_by])
  @@index([created_at])
  @@index([username])
}
