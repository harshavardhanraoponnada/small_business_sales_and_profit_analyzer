# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.local
.env.*.local

# Data files & backups (never commit)
/backend/src/data/*.csv
/backend/src/data/*.csv.backup
/backend/src/data/*.backup
/backend/src/data/audit_logs
/backend/src/data/audit_logs*
/backend/src/uploads/

# Generated reports (keep folder, ignore artifacts)
/ml-service/generated_reports/*
!/ml-service/generated_reports/.gitkeep

# Prisma
.prisma/
*.db
*.sqlite

# Logs
logs/
*.log

# Test coverage (regenerated on each run)
/backend/coverage/
/ml-service/coverage/
/frontend/coverage/

# Debug & temporary test files
debug_test.py
test_endpoints.py
*_test.py.tmp
*.debug.*

# OS / Editor
.vscode/
.idea/
.DS_Store
Thumbs.db
# Test report outputs (regenerated on each test run)
/backend/coverage_*.txt
/backend/test_*.txt
/backend/test-output.txt

# Disabled test archives (kept for reference but not executed)
**/*.test.js.disabled
