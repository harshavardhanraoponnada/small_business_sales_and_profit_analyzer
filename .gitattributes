# Normalize text files by default
* text=auto

# Keep Markdown and documentation files as LF across platforms
*.md text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.css text eol=lf
*.json text eol=lf

# Shell scripts should stay LF
*.sh text eol=lf

# Windows command scripts should use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
